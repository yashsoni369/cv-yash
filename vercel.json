{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; media-src 'self' data:; script-src 'self' 'unsafe-inline' https://vercel.live; style-src 'self' 'unsafe-inline' https://vercel.live; font-src 'self' https://vercel.live; img-src 'self' data: https:; connect-src 'self' https://vercel.live https://*.pusher.com wss://*.pusher.com https://va.vercel-scripts.com https://vitals.vercel-insights.com wss://api.openai.com https://api.openai.com; frame-src 'self' https://vercel.live https://www.youtube.com; frame-ancestors 'self'; form-action 'self'; base-uri 'self'; object-src 'none'"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(self), geolocation=()"
        },
        {
          "key": "X-Open-To",
          "value": "freelance-contracts"
        },
        {
          "key": "X-Built-With",
          "value": "Claude Code"
        },
        {
          "key": "X-Resume",
          "value": "/llms.txt"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/en", "destination": "/", "permanent": true },
    { "source": "/:path+/", "destination": "/:path+", "permanent": true }
  ],
  "rewrites": [
    { "source": "/es", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/es/about", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/es/privacy", "destination": "/index.html" },
    { "source": "/decoverai", "destination": "/index.html" },
    { "source": "/speakology-ai", "destination": "/index.html" },
    { "source": "/infinity-devops", "destination": "/index.html" },
    { "source": "/mappie-ai", "destination": "/index.html" },
    { "source": "/vectro-ai", "destination": "/index.html" },
    { "source": "/united-medical", "destination": "/index.html" },
    { "source": "/stethy", "destination": "/index.html" },
    { "source": "/noetic", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/evaluate",
      "schedule": "0 8 * * *"
    }
  ]
}
